{
  "$schema": "../schemas/crumbs.schema.json",
  "extensions": {
    "pathVisibility": {
      "enabled": true,
      "deny": [
        ".env",
        ".env.*",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.gnupg/**",
        "docs/_hidden/**"
      ],
      "injectPromptHint": true
    },
    "quietMarkdownlint": {
      "excludeGlobs": [
        "external/**",
        "docs/_hidden/**"
      ]
    },
    "quietMiseTask": {
      "task": "check",
      "excludeGlobs": [
        "external/**"
      ],
      "trackedExtensions": [
        ".ts"
      ]
    }
  },
  "mcpServers": {
    "pencil": {
      "command": "/Users/spadgett/.pencil/mcp/visual_studio_code/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "visual_studio_code"
      ],
      "lifecycle": "lazy",
      "enabled": false
    }
  }
}
