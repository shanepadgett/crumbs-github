{
  "$schema": "../schemas/crumbs.schema.json",
  "extensions": {
    "caveman": {
      "enabled": true,
      "powers": ["improve", "architecture", "typescript"],
      "additionalContext": {
        "all": ["AGENTS.md"],
        "powers": {}
      }
    },
    "quietMiseTask": {
      "globalExcludeGlobs": ["external/**", "docs/_hidden/**"],
      "configs": [
        {
          "name": "config",
          "task": "check:config",
          "trackedExtensions": [".json", ".toml"]
        },
        {
          "enabled": true,
          "name": "ts",
          "task": "check:ts",
          "trackedExtensions": [".js", ".jsx", ".ts", ".tsx"]
        },
        {
          "enabled": true,
          "name": "markdown",
          "task": "check:markdown",
          "trackedExtensions": [".md"]
        },
        {
          "enabled": true,
          "name": "yaml",
          "task": "check:yaml",
          "trackedExtensions": [".yml", ".yaml"]
        }
      ]
    },
    "mcp": {
      "mcpServers": {
        "pencil": {
          "command": "/Users/spadgett/.pencil/mcp/visual_studio_code/out/mcp-server-darwin-arm64",
          "args": ["--app", "visual_studio_code"],
          "lifecycle": "lazy",
          "requiresCavemanPower": "design"
        }
      }
    }
  }
}
