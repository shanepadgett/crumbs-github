{
  "$schema": "../schemas/crumbs.schema.json",
  "extensions": {
    "caveman": {
      "enabled": true,
      "powers": [
        "improve"
      ]
    },
    "quietMarkdownlint": {
      "excludeGlobs": [
        "external/**",
        "docs/_hidden/**"
      ]
    },
    "quietMiseTask": {
      "task": "check",
      "excludeGlobs": [
        "external/**"
      ],
      "trackedExtensions": [
        ".ts"
      ]
    },
    "mcp": {
      "mcpServers": {
        "pencil": {
          "command": "/Users/spadgett/.pencil/mcp/visual_studio_code/out/mcp-server-darwin-arm64",
          "args": [
            "--app",
            "visual_studio_code"
          ],
          "lifecycle": "lazy"
        }
      }
    }
  }
}