{
  "$schema": "https://raw.githubusercontent.com/shanepadgett/crumbs/refs/heads/main/schemas/crumbs.schema.json",
  "extensions": {
    "caveman": {
      "enabled": true,
      "powers": [
        "improve",
        "architecture",
        "typescript"
      ],
      "additionalContext": {
        "all": [
          "AGENTS.md"
        ],
        "powers": {}
      }
    },
    "quietMiseTask": {
      "configs": [
        {
          "name": "typescript",
          "task": "check:ts",
          "trackedExtensions": [
            ".ts"
          ],
          "excludeGlobs": [
            "external/**",
            "node_modeules/**"
          ]
        },
        {
          "name": "config",
          "task": "check:config",
          "trackedExtensions": [
            ".json",
            ".toml"
          ],
          "excludeGlobs": [
            "external/**",
            "node_modeules/**"
          ]
        }
      ]
    },
    "mcp": {
      "mcpServers": {
        "pencil": {
          "command": "/Users/spadgett/.pencil/mcp/visual_studio_code/out/mcp-server-darwin-arm64",
          "args": [
            "--app",
            "visual_studio_code"
          ],
          "lifecycle": "lazy",
          "requiresCavemanPower": "design"
        }
      }
    }
  }
}
