{
  "$schema": "../schemas/crumbs.schema.json",
  "permissions": {
    "mode": "workspace",
    "modes": {
      "research": {
        "label": "research",
        "base": "read-only",
        "networkMode": "open",
        "direct": {
          "mutation": "paths",
          "allowPaths": ["docs/research/**/*.md", "docs/notes/**/*.md", "docs/plans/**/*.md"]
        },
        "shell": {
          "writeRoots": [".git/", "/tmp"]
        }
      }
    },
    "blockedPaths": [".env", ".env.*", "~/.ssh/", "~/.aws/", "~/.gnupg/", "docs/_hidden/"],
    "protectedMutationPaths": [
      ".pi/crumbs.json",
      "AGENTS.md",
      "tsconfig.json",
      "bun.lock",
      ".markdownlint.yaml",
      ".gitignore"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "npmjs.org",
        "*.npmjs.org",
        "mcp.exa.ai"
      ]
    },
    "ui": {
      "showFooterStatus": true
    },
    "destructive": {
      "onNoUi": "deny"
    }
  }
}
