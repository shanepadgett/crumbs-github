{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crumbs.dev/schemas/crumbs.schema.json",
  "title": "Crumbs Configuration",
  "description": "Configuration for the Crumbs package and its extensions.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference used by editors for validation and autocomplete."
    },
    "tools": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "properties": {
        "pathVisibility": {
          "$ref": "#/$defs/pathVisibilityConfig"
        },
        "quietMarkdownlint": {
          "$ref": "#/$defs/quietMarkdownlintConfig"
        },
        "quietMiseTask": {
          "$ref": "#/$defs/quietMiseTaskConfig"
        },
        "quietXcodeBuild": {
          "$ref": "#/$defs/quietXcodeBuildConfig"
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": true
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "pathVisibilityConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable path visibility blocking."
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Glob patterns for denied files and folders."
        },
        "injectPromptHint": {
          "type": "boolean",
          "default": true,
          "description": "Inject a short agent prompt hint that lists denied path patterns."
        }
      },
      "additionalProperties": false,
      "default": {
        "enabled": true,
        "deny": [
          ".env",
          ".env.*",
          "~/.ssh/**",
          "~/.aws/**",
          "~/.gnupg/**"
        ],
        "injectPromptHint": true
      }
    },
    "quietMiseTaskConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from tracked file scanning.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietMarkdownlintConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from markdownlint tracking.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietXcodeBuildConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Base app name. Used to derive <name>/, <name>.xcodeproj, optional <name>.xcworkspace, and scheme <name>."
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "$schema": "https://crumbs.dev/schemas/crumbs.schema.json",
      "extensions": {
        "pathVisibility": {
          "enabled": true,
          "deny": [
            "docs/_hidden/**",
            "external/**",
            ".env",
            ".env.*",
            "~/.ssh/**"
          ],
          "injectPromptHint": true
        },
        "quietMarkdownlint": {
          "enabled": true,
          "excludeGlobs": [
            "docs/_hidden/**",
            "external/**"
          ]
        },
        "quietMiseTask": {
          "enabled": true,
          "task": "check",
          "trackedExtensions": [
            ".swift",
            ".ts",
            ".tsx",
            ".js",
            ".jsx",
            ".java"
          ],
          "excludeGlobs": [
            "external/**"
          ]
        },
        "quietXcodeBuild": {
          "enabled": true,
          "name": "athenavoice"
        }
      }
    }
  ]
}
