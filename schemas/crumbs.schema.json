{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crumbs.dev/schemas/crumbs.schema.json",
  "title": "Crumbs Configuration",
  "description": "Configuration for the Crumbs package and its extensions.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference used by editors for validation and autocomplete."
    },
    "permissions": {
      "$ref": "#/$defs/permissionsConfig"
    },
    "tools": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "properties": {
        "quietMarkdownlint": {
          "$ref": "#/$defs/quietMarkdownlintConfig"
        },
        "quietMiseTask": {
          "$ref": "#/$defs/quietMiseTaskConfig"
        },
        "quietXcodeBuild": {
          "$ref": "#/$defs/quietXcodeBuildConfig"
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": true
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "permissionsModeBase": {
      "type": "string",
      "enum": ["read-only", "workspace", "full-access"]
    },
    "permissionsNetworkMode": {
      "type": "string",
      "enum": ["restricted", "open"]
    },
    "permissionsDirectMutationPolicy": {
      "type": "string",
      "enum": ["none", "workspace", "any", "paths"]
    },
    "permissionsDestructivePolicy": {
      "type": "string",
      "enum": ["block", "prompt", "allow"]
    },
    "permissionsOnNoUi": {
      "type": "string",
      "enum": ["deny", "allow"],
      "default": "deny"
    },
    "permissionsNetwork": {
      "type": "object",
      "properties": {
        "allowedDomains": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "allowedDomains": []
      }
    },
    "permissionsUi": {
      "type": "object",
      "properties": {
        "showFooterStatus": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false,
      "default": {
        "showFooterStatus": true
      }
    },
    "permissionsDestructive": {
      "type": "object",
      "properties": {
        "onNoUi": {
          "$ref": "#/$defs/permissionsOnNoUi"
        }
      },
      "additionalProperties": false,
      "default": {
        "onNoUi": "deny"
      }
    },
    "permissionsModeDirect": {
      "type": "object",
      "properties": {
        "mutation": {
          "$ref": "#/$defs/permissionsDirectMutationPolicy"
        },
        "allowPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "permissionsModeShell": {
      "type": "object",
      "properties": {
        "writeRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "permissionsModeDefinition": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "base": {
          "$ref": "#/$defs/permissionsModeBase"
        },
        "sandbox": {
          "type": "boolean"
        },
        "networkMode": {
          "$ref": "#/$defs/permissionsNetworkMode"
        },
        "direct": {
          "$ref": "#/$defs/permissionsModeDirect"
        },
        "shell": {
          "$ref": "#/$defs/permissionsModeShell"
        },
        "destructive": {
          "$ref": "#/$defs/permissionsDestructivePolicy"
        }
      },
      "required": ["base"],
      "additionalProperties": false
    },
    "permissionsModes": {
      "type": "object",
      "description": "Custom named permission modes. Built-in mode keys are read-only, read-only-open, workspace, workspace-open, and full-access.",
      "additionalProperties": {
        "$ref": "#/$defs/permissionsModeDefinition"
      },
      "default": {}
    },
    "permissionsConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Active mode key. Built-in keys are read-only, read-only-open, workspace, workspace-open, and full-access. Custom keys can be defined in permissions.modes.",
          "default": "workspace"
        },
        "modes": {
          "$ref": "#/$defs/permissionsModes"
        },
        "blockedPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "protectedMutationPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "network": {
          "$ref": "#/$defs/permissionsNetwork"
        },
        "ui": {
          "$ref": "#/$defs/permissionsUi"
        },
        "destructive": {
          "$ref": "#/$defs/permissionsDestructive"
        }
      },
      "additionalProperties": false,
      "default": {
        "mode": "workspace",
        "modes": {},
        "blockedPaths": [".env", ".env.*", "~/.ssh/", "~/.aws/", "~/.gnupg/"],
        "protectedMutationPaths": [".pi/crumbs.json"],
        "network": {
          "allowedDomains": [
            "github.com",
            "*.github.com",
            "api.github.com",
            "raw.githubusercontent.com",
            "registry.npmjs.org",
            "npmjs.org",
            "*.npmjs.org",
            "mcp.exa.ai"
          ]
        },
        "ui": {
          "showFooterStatus": true
        },
        "destructive": {
          "onNoUi": "deny"
        }
      }
    },
    "quietMiseTaskConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from tracked file scanning.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietMarkdownlintConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from markdownlint tracking.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietXcodeBuildConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Base app name. Used to derive <name>/, <name>.xcodeproj, optional <name>.xcworkspace, and scheme <name>."
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "$schema": "https://crumbs.dev/schemas/crumbs.schema.json",
      "extensions": {
        "quietMarkdownlint": {
          "enabled": true,
          "excludeGlobs": ["docs/_hidden/**", "external/**"]
        },
        "quietMiseTask": {
          "enabled": true,
          "task": "check",
          "trackedExtensions": [".swift", ".ts", ".tsx", ".js", ".jsx", ".java"],
          "excludeGlobs": ["external/**"]
        },
        "quietXcodeBuild": {
          "enabled": true,
          "name": "athenavoice"
        }
      },
      "permissions": {
        "mode": "workspace",
        "modes": {
          "research": {
            "label": "research",
            "base": "read-only",
            "networkMode": "open",
            "direct": {
              "mutation": "paths",
              "allowPaths": ["research/**/*.md", "notes/**/*.md", "plans/**/*.md"]
            },
            "shell": {
              "writeRoots": ["/tmp"]
            }
          }
        },
        "blockedPaths": [".env", ".env.*", "~/.ssh/", "~/.aws/", "~/.gnupg/"],
        "protectedMutationPaths": [".pi/crumbs.json"],
        "network": {
          "allowedDomains": [
            "github.com",
            "*.github.com",
            "api.github.com",
            "raw.githubusercontent.com",
            "registry.npmjs.org",
            "npmjs.org",
            "*.npmjs.org",
            "mcp.exa.ai"
          ]
        },
        "ui": {
          "showFooterStatus": true
        },
        "destructive": {
          "onNoUi": "deny"
        }
      }
    }
  ]
}
