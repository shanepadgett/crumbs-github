{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crumbs.dev/schemas/crumbs.schema.json",
  "title": "Crumbs Configuration",
  "description": "Configuration for the Crumbs package and its extensions.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference used by editors for validation and autocomplete."
    },
    "tools": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "properties": {
        "quietMiseTask": {
          "$ref": "#/$defs/quietMiseTaskConfig"
        },
        "statusTable": {
          "$ref": "#/$defs/statusTableConfig"
        },
        "codexCompat": {
          "$ref": "#/$defs/codexCompatConfig"
        },
        "commit": {
          "$ref": "#/$defs/commitConfig"
        },
        "caveman": {
          "$ref": "#/$defs/cavemanConfig"
        },
        "mcp": {
          "$ref": "#/$defs/mcpConfig"
        },
        "mcpDirect": {
          "$ref": "#/$defs/mcpConfig"
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": true
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "quietMiseTaskConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from tracked file scanning.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "configs": {
          "type": "array",
          "description": "Multiple mise task configs. When present, these entries replace the legacy single-task fields above.",
          "items": {
            "$ref": "#/$defs/quietMiseTaskEntry"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietMiseTaskEntry": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional display label for this task config. Defaults to task name."
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from tracked file scanning.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "statusTableConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the status table widget by default."
        },
        "mode": {
          "type": "string",
          "enum": ["full", "minimal"],
          "default": "full",
          "description": "Default status table rendering mode."
        }
      },
      "additionalProperties": false
    },
    "codexCompatConfig": {
      "type": "object",
      "properties": {
        "fast": {
          "type": "boolean",
          "default": false,
          "description": "Enable OpenAI/OpenAI Codex priority service tier for supported requests."
        }
      },
      "additionalProperties": false
    },
    "commitConfig": {
      "type": "object",
      "properties": {
        "allowedTypes": {
          "type": "array",
          "description": "Conventional commit types the /commit agent may use. Custom repo-specific types are allowed. When provided, this replaces the built-in default list.",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
          },
          "uniqueItems": true,
          "minItems": 1,
          "default": [
            "feat",
            "fix",
            "docs",
            "style",
            "refactor",
            "perf",
            "test",
            "build",
            "ci",
            "chore",
            "revert"
          ]
        },
        "allowBreakingChangeMarker": {
          "type": "boolean",
          "default": true,
          "description": "Allow the /commit agent to use the Conventional Commits ! marker, such as feat! or fix!, only for true breaking changes."
        }
      },
      "additionalProperties": false
    },
    "cavemanConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Caveman system prompt mode by default."
        },
        "powers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["improve", "design", "architecture", "swiftui", "typescript"]
          },
          "uniqueItems": true,
          "default": [],
          "description": "Optional Caveman powers. improve adds Pi self-improvement guidance. design adds UX and interface-shaping guidance. architecture adds stronger ownership and abstraction judgment. swiftui adds modern SwiftUI guidance. typescript adds stronger TypeScript guidance."
        },
        "enhancements": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["improve", "design", "architecture", "swiftui", "typescript"]
          },
          "uniqueItems": true,
          "default": [],
          "description": "Deprecated legacy alias for powers. Use powers instead."
        },
        "additionalContext": {
          "type": "object",
          "description": "Additional context files whose contents are injected into the Caveman system prompt.",
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true,
              "default": [],
              "description": "Files injected whenever Caveman is enabled. Relative paths resolve from project root."
            },
            "powers": {
              "type": "object",
              "description": "Files injected only when matching Caveman power is active.",
              "properties": {
                "improve": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "design": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "architecture": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "swiftui": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "typescript": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {
            "all": [],
            "powers": {}
          }
        }
      },
      "additionalProperties": false
    },
    "cavemanAdditionalContextPathList": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "mcpConfig": {
      "type": "object",
      "properties": {
        "mcpServers": {
          "type": "object",
          "description": "Named MCP server entries.",
          "additionalProperties": {
            "$ref": "#/$defs/mcpServerConfig"
          },
          "default": {}
        }
      },
      "additionalProperties": false,
      "default": {
        "mcpServers": {}
      }
    },
    "mcpServerConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable this server entry."
        },
        "requiresCavemanPower": {
          "type": "string",
          "enum": ["improve", "design", "architecture", "swiftui", "typescript"],
          "description": "Enable this server only when Caveman is enabled and this power is active."
        },
        "lifecycle": {
          "type": "string",
          "enum": ["lazy", "eager"],
          "default": "lazy",
          "description": "Server startup policy."
        },
        "command": {
          "type": "string",
          "description": "Stdio mode executable command."
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Stdio mode command arguments."
        },
        "cwd": {
          "type": "string",
          "description": "Optional working directory for stdio mode."
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional environment variables for stdio mode."
        },
        "url": {
          "type": "string",
          "description": "HTTP mode server URL."
        },
        "serverUrl": {
          "type": "string",
          "description": "Legacy alias for url."
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional HTTP headers."
        },
        "bearerToken": {
          "type": "string",
          "description": "Optional static bearer token for HTTP mode."
        },
        "bearerTokenEnv": {
          "type": "string",
          "description": "Environment variable name to read bearer token from."
        }
      },
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "$schema": "https://crumbs.dev/schemas/crumbs.schema.json",
      "extensions": {
        "quietMiseTask": {
          "enabled": true,
          "configs": [
            {
              "name": "swift",
              "task": "check:swift",
              "trackedExtensions": [".swift"],
              "excludeGlobs": ["external/**"]
            },
            {
              "name": "web",
              "task": "check:web",
              "trackedExtensions": [".ts", ".tsx", ".js", ".jsx"]
            }
          ]
        }
      }
    }
  ]
}
