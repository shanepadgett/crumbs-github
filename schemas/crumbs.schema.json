{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crumbs.dev/schemas/crumbs.schema.json",
  "title": "Crumbs Configuration",
  "description": "Configuration for the Crumbs package and its extensions.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference used by editors for validation and autocomplete."
    },
    "tools": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "properties": {
        "pathVisibility": {
          "$ref": "#/$defs/pathVisibilityConfig"
        },
        "focusAdvanced": {
          "$ref": "#/$defs/focusAdvancedConfig"
        },
        "quietMarkdownlint": {
          "$ref": "#/$defs/quietMarkdownlintConfig"
        },
        "quietMiseTask": {
          "$ref": "#/$defs/quietMiseTaskConfig"
        },
        "quietXcodeBuild": {
          "$ref": "#/$defs/quietXcodeBuildConfig"
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": true
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "pathVisibilityConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable path visibility blocking."
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Legacy alias for hardDeny. Prefer hardDeny."
        },
        "hardDeny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Glob patterns that are always blocked from direct reads and hidden from bash output."
        },
        "injectPromptHint": {
          "type": "boolean",
          "default": true,
          "description": "Inject a short agent prompt hint that lists denied path patterns."
        },
        "focus": {
          "$ref": "#/$defs/focusConfig"
        }
      },
      "additionalProperties": false,
      "default": {
        "enabled": true,
        "hardDeny": [
          ".env",
          ".env.*",
          "~/.ssh/**",
          "~/.aws/**",
          "~/.gnupg/**"
        ],
        "injectPromptHint": true,
        "focus": {
          "enabled": false,
          "mode": "hidden",
          "roots": [],
          "alwaysAllow": []
        }
      }
    },
    "focusConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable focus steering for agent exploration scope."
        },
        "mode": {
          "type": "string",
          "enum": [
            "soft",
            "hidden",
            "hard"
          ],
          "default": "hidden",
          "description": "soft=prompt steering, hidden=steering+masking, hard=block outside focus roots."
        },
        "roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Preferred focus roots for exploration and edits."
        },
        "alwaysAllow": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Paths always allowed even in hard focus mode."
        }
      },
      "additionalProperties": false,
      "default": {
        "enabled": false,
        "mode": "hidden",
        "roots": [],
        "alwaysAllow": []
      }
    },
    "focusAdvancedConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Focus Advanced by default for this project."
        },
        "mode": {
          "type": "string",
          "enum": [
            "soft",
            "hidden",
            "hard"
          ],
          "default": "hidden",
          "description": "soft=prompt steering, hidden=custom discovery tools plus bash discovery blocking and permission prompts for outside paths, hard=requires permission prompts for outside path access."
        },
        "roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Default focus roots for Focus Advanced."
        },
        "alwaysAllow": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Extra paths allowed even when they sit outside focus roots."
        },
        "injectPromptHint": {
          "type": "boolean",
          "default": true,
          "description": "Inject Focus Advanced tool guidance into the system prompt."
        }
      },
      "additionalProperties": false,
      "default": {
        "enabled": false,
        "mode": "hidden",
        "roots": [],
        "alwaysAllow": [],
        "injectPromptHint": true
      }
    },
    "quietMiseTaskConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from tracked file scanning.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietMarkdownlintConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs to exclude from markdownlint tracking.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietXcodeBuildConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Base app name. Used to derive <name>/, <name>.xcodeproj, optional <name>.xcworkspace, and scheme <name>."
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "$schema": "https://crumbs.dev/schemas/crumbs.schema.json",
      "extensions": {
        "pathVisibility": {
          "enabled": true,
          "hardDeny": [
            "docs/_hidden/**",
            ".env",
            ".env.*",
            "~/.ssh/**"
          ],
          "injectPromptHint": true,
          "focus": {
            "enabled": true,
            "mode": "hidden",
            "roots": [
              "extensions/path-visibility"
            ],
            "alwaysAllow": [
              ".pi/crumbs.json",
              "schemas/crumbs.schema.json"
            ]
          }
        },
        "quietMarkdownlint": {
          "enabled": true,
          "excludeGlobs": [
            "docs/_hidden/**",
            "external/**"
          ]
        },
        "quietMiseTask": {
          "enabled": true,
          "task": "check",
          "trackedExtensions": [
            ".swift",
            ".ts",
            ".tsx",
            ".js",
            ".jsx",
            ".java"
          ],
          "excludeGlobs": [
            "external/**"
          ]
        },
        "quietXcodeBuild": {
          "enabled": true,
          "name": "athenavoice"
        }
      }
    }
  ]
}
