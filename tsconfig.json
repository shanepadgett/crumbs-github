{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force"
  },
  "include": [
    "extensions/**/*.ts",
    "extensions/**/*.d.ts",
    ".pi/extensions/**/*.ts",
    ".pi/extensions/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
