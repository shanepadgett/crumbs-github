{
  "name": "crumbs-pi-extensions",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi extensions packaged for local install/uninstall.",
  "keywords": [
    "pi-package"
  ],
  "workspaces": [
    "extensions/caveman",
    "extensions/codex-compat",
    "extensions/commit",
    "extensions/crumbs-doctor",
    "extensions/mcp",
    "extensions/notify",
    "extensions/quiet-validators",
    "extensions/skills-manager",
    "extensions/status-table",
    "extensions/subagents",
    "extensions/terminal-clear",
    "extensions/web"
  ],
  "type": "module",
  "scripts": {
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "node-pty": "1.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.72.1",
    "@mariozechner/pi-coding-agent": "0.72.1",
    "@mariozechner/pi-tui": "0.72.1",
    "@sinclair/typebox": "0.34.49",
    "@types/node": "25.5.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "6.0.2"
  },
  "trustedDependencies": [
    "node-pty"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
